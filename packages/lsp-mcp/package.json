{
  "name": "@quebi/lsp-mcp",
  "version": "0.0.0",
  "description": "HTTP MCP service that exposes LSP-backed code intelligence (definitions, references, hover, diagnostics, symbols) as MCP tools.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lsp-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "start": "bun run ./src/index.ts serve",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
